# Application
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=servicios_sociales_db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://admin:secretpassword@localhost:5432/servicios_sociales_db"

# Redis
REDIS_PASSWORD=redispassword
REDIS_PORT=6379
REDIS_URL="redis://:redispassword@localhost:6379"

# JWT Configuration (generar con openssl o scripts/generate-keys.sh)
# Copiar el contenido de keys/private.pem y keys/public.pem AQUÍ
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/oauth/callback/google

# OAuth2 - Azure AD
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CALLBACK_URL=http://localhost:3000/oauth/callback/azure

# OAuth2 - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/oauth/callback/github

# Security
CSRF_SECRET=your-csrf-secret-key-min-32-characters-long
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email (SMTP Configuration)
# Opción A: Ethereal (Recomendado para pruebas locales)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-user
SMTP_PASS=your-ethereal-password

# Opción B: Gmail (Requiere Contraseña de Aplicación)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Opción C: Outlook/Hotmail (Requiere Contraseña de Aplicación)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@hotmail.com
# SMTP_PASS=your-app-password

# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your_google_recaptcha_v3_secret_key
