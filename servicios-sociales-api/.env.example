# ---------------------------------------------------------
# Copia este archivo como .env y completa los valores
# ---------------------------------------------------------

# Application
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001

# Database (Local Docker)
POSTGRES_USER=admin
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=servicios_sociales_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:secretpassword@localhost:5432/servicios_sociales_db

# Redis (Local Docker)
REDIS_PASSWORD=redispassword
REDIS_PORT=6379
REDIS_URL="redis://:redispassword@localhost:6379"

# JWT Configuration (IMPORTANTE: Cada dev debe generar las suyas)
# Comando para generar: npm run generate:keys (si tienes el script)
# O usa valores aleatorios largos para desarrollo local.
JWT_PRIVATE_KEY="PONER_AQUI_UNA_LLAVE_PRIVADA_RSA"
JWT_PUBLIC_KEY="PONER_AQUI_UNA_LLAVE_PUBLICA_RSA"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth2 - Google (Obtener en console.cloud.google.com)
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/oauth/callback/google

# Google reCAPTCHA v3 (Obtener en google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=tu-recaptcha-secret-key

# Email (Pruebas con Ethereal.email)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-usuario-ethereal
SMTP_PASS=tu-password-ethereal

# Security
CSRF_SECRET=llave-aleatoria-de-mas-de-32-caracteres
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
